rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function myEmail() {
      return request.auth.token.email.lower();
    }

    function isParticipant(conversation) {
      return signedIn()
        && conversation.data.participants is list
        && myEmail() in conversation.data.participants;
    }

    function validProfileWrite() {
      return signedIn()
        && request.resource.data.email is string
        && request.resource.data.email.lower() == myEmail()
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'profilePhoto', 'createdAt', 'updatedAt', 'lastActive'
        ]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if validProfileWrite();
      allow delete: if signedIn() && resource.data.email.lower() == myEmail();
    }

    match /conversations/{conversationId} {
      allow read: if isParticipant(resource);
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50
        && myEmail() in request.resource.data.participants;
      allow update: if isParticipant(resource)
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)));
        allow create: if isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)))
          && request.resource.data.sender.lower() == myEmail()
          && request.resource.data.keys().hasOnly([
            'sender', 'text', 'imageUrl', 'audioUrl', 'audioType', 'audioDurationMs', 'createdAt', 'reactions', 'readBy'
          ]);
        allow update: if isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)));
        allow delete: if isParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)))
          && resource.data.sender.lower() == myEmail();
      }
    }
  }
}
